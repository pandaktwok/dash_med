# Copie para `.env` e ajuste. O `.env` nunca vai para o git.

# Banco local SQLite. O arquivo dev.db e gerado por `prisma db push`
# (ou `prisma migrate dev` a partir da Etapa 1.2) e tambem nao vai para o git.
DATABASE_URL="file:./dev.db"

# --- Variaveis previstas para as proximas etapas (ainda nao usadas) ---
# Ver relatorio-avaliacao.md para o contexto de cada integracao.

# Etapa 4 — WhatsApp / IA (bloqueada: provedor de conexao nao decidido)
# WHATSAPP_PROVIDER_URL=
# WHATSAPP_API_TOKEN=
# WHATSAPP_WEBHOOK_KEY=
# OPENCLAW_WEBHOOK_SECRET=

# Etapa 5 — Google Calendar (somente blocos de horario, nunca dado clinico)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=
# CALENDAR_ID=

# Etapa 6 — Licenciamento
# LICENSE_API_URL=
# LICENSE_KEY=
